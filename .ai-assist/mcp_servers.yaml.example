# MCP Server Configuration for ai-assist
# Copy this file to ~/.ai-assist/mcp_servers.yaml and customize

servers:
  # DCI MCP Server - Production version from PyPI
  dci:
    command: "uvx"
    args: ["--from", "dci-mcp-server", "dci-mcp-server"]
    env:
      DCI_CLIENT_ID: "${DCI_CLIENT_ID}"
      DCI_API_SECRET: "${DCI_API_SECRET}"
      DCI_CS_URL: "${DCI_CS_URL}"
      JIRA_API_TOKEN: "${JIRA_API_TOKEN}"
      JIRA_URL: "${JIRA_URL}"
      GOOGLE_APPLICATION_CREDENTIALS: "${GOOGLE_APPLICATION_CREDENTIALS}"
      MCP_SHOW_BANNER: "false"
    # Pagination config for __collect_to_report auto-pagination
    pagination:
      offset_param: offset
      limit_param: limit
      default_page_size: 200
      total_field: _meta.count
      data_field: auto
      tool_overrides:
        search_dci_jobs:
          total_field: total
          data_field: hits
        search_github_issues:
          limit_param: max_results
          total_field: total_count
          data_field: items
        search_jira_tickets:
          limit_param: max_results
          total_field: total_count
          data_field: items

  # DCI MCP Server - Local development version
  dci-local:
    enabled: false
    command: "/home/user/work/dci-mcp-server/.venv/bin/python"
    args: ["/home/user/work/dci-mcp-server/main.py"]
    env:
      MCP_SHOW_BANNER: "false"

  # Reports MCP Server - For markdown report management
  # Uncomment to enable report generation and management
  # reports:
  #   command: "uvx"
  #   args: ["--from", "ai-assist-reports-mcp-server", "ai-assist-reports-mcp-server"]
  #   env:
  #     AI_ASSIST_REPORTS_DIR: "${HOME}/ai-assist/reports"

  # Add your custom MCP servers here
  # my-custom-server:
  #   command: "node"
  #   args: ["./my-server.js"]
  #   env:
  #     API_KEY: "${MY_API_KEY}"
