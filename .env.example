# Anthropic API Configuration (REQUIRED - Choose ONE method)
#
# METHOD 1: Vertex AI (Google Cloud) - Recommended for enterprise
# Use this if your company uses Claude via Google Cloud Vertex AI
# Requires: gcloud auth application-default login
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# ANTHROPIC_VERTEX_REGION=us-east5  # Optional - SDK auto-selects region if not specified
#
# METHOD 2: Direct API Key - For personal use or free tier
# Get your API key from: https://console.anthropic.com/
# Free tier available ($5 credit for new accounts)
ANTHROPIC_API_KEY=your_api_key_here
#
# Model configuration (applies to both methods)
# For Claude 4.6+ use dateless IDs (e.g., claude-sonnet-4-6, claude-opus-4-6)
# For older models use @ format (e.g., claude-sonnet-4-5@20250929)
AI_ASSIST_MODEL=claude-sonnet-4-6

# Notification Settings
ENABLE_NOTIFICATIONS=true
NOTIFICATION_CHANNEL=console

# Report directory
AI_ASSIST_REPORTS_DIR=~/ai-assist/reports

# Agent Skills Script Execution (SECURITY: Disabled by default)
# WARNING: Enabling this allows installed Agent Skills to execute scripts
# Only enable if you trust the skills you install from third parties
# See SECURITY.md for details on security controls
# AI_ASSIST_ALLOW_SCRIPT_EXECUTION=true

# Context Window
# Claude 4.6+ models have native 1M context windows (no opt-in needed)

# Slack Webhook Integration (optional - for slack-webhook skill)
# See skills/slack-webhook/SKILL.md for setup instructions
# Create incoming webhooks at: https://api.slack.com/apps
#
# Personal/logs channel (default) - used when no channel specified
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/XXX
#
# Team/announcements channel - used when "team" or "équipe" mentioned
# SLACK_TEAM_WEBHOOK_URL=https://hooks.slack.com/services/T00/B01/YYY
