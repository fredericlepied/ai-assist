# ai-assist sandbox credentials
# Copy this file to .env and fill in your credentials.
# Each variable is injected ONLY into the service that needs it (see compose.yaml).

# Claude API (ai-assist container only)
ANTHROPIC_API_KEY=
# Or for Vertex AI:
# ANTHROPIC_VERTEX_PROJECT_ID=
# ANTHROPIC_VERTEX_REGION=

# DCI (dci-mcp-server container only)
DCI_CLIENT_ID=
DCI_API_SECRET=
# DCI_CS_URL=https://api.distributed-ci.io/api/v1

# Jira (dci-mcp-server container only)
JIRA_API_TOKEN=
# JIRA_URL=https://redhat.atlassian.net
# JIRA_WRITE_ENABLED=false

# GitHub (dci-mcp-server container only)
GITHUB_TOKEN=

# GitLab (dci-mcp-server container only)
GITLAB_TOKEN=
# GITLAB_URL=https://gitlab.cee.redhat.com

# Red Hat API (dci-mcp-server container only)
OFFLINE_TOKEN=
